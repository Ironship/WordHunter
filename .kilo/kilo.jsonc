{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "opencode-go/deepseek-v4-flash",
  "small_model": "opencode-go/deepseek-v4-flash",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1",
        "apiKey": "sk-lm-studio",
        "timeout": false,
        "headerTimeout": 120000
      },
      "models": {
        "qwen3.6-35b-a3b": {
          "name": "Qwen3.6 35B A3B IQ2",
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "qwen3.6-35b-a3b-mtp": {
          "name": "Qwen3.6 35B A3B MTP",
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "qwen3.6-27b-mtp@iq4_nl": {
          "name": "Qwen3.6 27B MTP IQ4_NL",
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "qwen3.6-27b-mtp@iq3_xxs": {
          "name": "Qwen3.6 27B MTP IQ3_XXS",
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  },
  "plugin": [
    "kilo-indexing"
  ],
  "indexing": {
    "enabled": true,
    "provider": "openai-compatible",
    "model": "text-embedding-qwen3-embedding-4b",
    "dimension": 2560,
    "openai-compatible": {
      "baseUrl": "http://127.0.0.1:1234/v1",
      "apiKey": "sk-lm-studio"
    },
    "vectorStore": "lancedb",
    "lancedb": {},
    "searchMinScore": 0.4,
    "searchMaxResults": 50,
    "embeddingBatchSize": 4,
    "scannerMaxBatchRetries": 3
  }
}
