<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>wordhunter</id>
    <version>1.0.6</version>
    <title>Word Hunter</title>
    <authors>Ironship</authors>
    <owners>Ironship</owners>
    <projectUrl>https://ironship.github.io/WordHunter-site/</projectUrl>
    <projectSourceUrl>https://github.com/Ironship/WordHunter</projectSourceUrl>
    <packageSourceUrl>https://github.com/Ironship/WordHunter/tree/main/packaging/chocolatey</packageSourceUrl>
