    <licenseUrl>https://github.com/Ironship/WordHunter/blob/WordHunter1.0.6/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <iconUrl>https://raw.githubusercontent.com/Ironship/WordHunter/WordHunter1.0.6/src/assets/icon-256.png</iconUrl>
