{
  "$schema": "./gen/schemas/desktop-schema.json",
  "productName": "Word Hunter",
  "version": "0.3.6",
  "identifier": "com.wordhunter.app",
  "build": {
    "frontendDist": "../src/web"
  },
  "app": {
    "windows": [],
    "enableGTKAppId": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "../src/assets/icon-32.png",
      "../src/assets/icon-128.png",
      "../src/assets/icon-256.png",
      "../src/assets/icon.ico"
    ],
    "resources": [
      "../src/assets/**/*",
      "ocr-runtime/bin/**/*",
      "ocr-runtime/models/**/*"
    ]
  }
}
