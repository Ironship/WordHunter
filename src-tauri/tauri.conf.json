{
  "$schema": "./gen/schemas/desktop-schema.json",
  "productName": "Word Hunter",
  "version": "1.0.5-rc.1",
  "identifier": "com.wordhunter.app",
  "build": {
    "frontendDist": "../dist/web"
  },
  "app": {
    "windows": [],
    "enableGTKAppId": true,
    "security": {
      "csp": "base-uri 'none'; object-src 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "licenseFile": "../LICENSE",
    "icon": [
      "../src/assets/icon-32.png",
      "../src/assets/icon-128.png",
      "../src/assets/icon-256.png",
      "../src/assets/icon.ico"
    ],
    "resources": {
      "../src/assets/**/*": "src/assets/",
      "../LICENSE": "LICENSE",
      "../THIRD-PARTY-NOTICES.md": "THIRD-PARTY-NOTICES.md",
      "../THIRD-PARTY-LICENSES.html": "THIRD-PARTY-LICENSES.html",
      "../OCR-THIRD-PARTY-LICENSES.html": "OCR-THIRD-PARTY-LICENSES.html"
    }
  }
}
